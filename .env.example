# ---------------------------------------------------------------------------
# Supabase (self-hosted, shared database)
# Metal My Mini uses the "metal" PostgreSQL schema only.
# ---------------------------------------------------------------------------

# Supabase API / Studio (port 54321 on your LAN server)
NEXT_PUBLIC_SUPABASE_URL="http://192.168.0.146:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-publishable-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"
NEXT_PUBLIC_SUPABASE_SCHEMA="metal"

# ---------------------------------------------------------------------------
# Prisma / direct Postgres (required for this app)
# ---------------------------------------------------------------------------
#
# The keys above are for the Supabase REST API. Prisma connects directly to
# Postgres. On self-hosted Supabase the database port is usually 54322.
#
# Find the postgres password in your Supabase install .env on the server
# (POSTGRES_PASSWORD). Default local dev password is often "postgres".
#
# From the Ubuntu server itself:
#   DATABASE_URL="postgresql://postgres:POSTGRES_PASSWORD@127.0.0.1:54322/postgres"
#
# From your Mac / other LAN machines:
#   DATABASE_URL="postgresql://postgres:POSTGRES_PASSWORD@192.168.0.146:54322/postgres"

DATABASE_URL="postgresql://postgres:POSTGRES_PASSWORD@192.168.0.146:54322/postgres"
DIRECT_URL="postgresql://postgres:POSTGRES_PASSWORD@192.168.0.146:54322/postgres"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3009"
NODE_ENV="development"
PORT=3009

# Auth / sessions (use a long random string in production)
SESSION_SECRET="change-this-to-a-long-random-secret-at-least-32-characters"

# Admin seed user (used by npm run db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-strong-password"

# File storage (outside public web root)
STORAGE_PATH="./storage"
MAX_UPLOAD_SIZE_MB=100

# Stripe (future integration)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Dev-only payment simulation (never enable in production)
ALLOW_DEV_PAYMENT="true"
